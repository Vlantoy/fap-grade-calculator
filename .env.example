# Copy to .env for `vercel dev` (do not commit .env)
GEMINI_API_KEY=AQ.your_gemini_key_here

# Optional: multiple keys (comma or newline) for rotation when quota hits
# GEMINI_API_KEYS=AQ.key1,AQ.key2,AQ.key3

# Prefer gemini-2.5-flash (2.0-flash free tier often exhausted)
# GEMINI_MODEL=gemini-2.5-flash
